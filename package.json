    "react-dom": "19",
    "react-quill-new": "^3.8.3",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "tailwind-merge": "^2.6.1",
    "unified": "^11.0.5",
    "unist": "^0.0.1",
    "zundo": "^2.3.0",
    "zustand": "^5.0.12"
  },
  "overrides": {
    "tar": "^7.5.6",
    "nanoid": "^3.3.8",
    "undici": "^6.23.0",
    "form-data": "^4.0.4",
    "js-yaml": "^4.1.1",
    "glob": "^10.5.0",
    "node-forge": "^1.3.2",
    "mdast-util-to-hast": "^13.2.1",
    "qs": "^6.14.1"
  }
}
