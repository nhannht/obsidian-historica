{
  "name": "obsidian-historica",
  "version": "0.3.6",
  "description": "Intelligently generates timeline from your content ... like a bro!",
  "main": "main.js",
  "scripts": {
    "dev": "concurrently \"bun run css\" \"bun run esbuild\" ",
    "css": "tailwindcss -i src/style/src.css -o styles.css --watch",
    "esbuild": "node esbuild.config.mjs",
    "build": "tailwindcss -i src/style/src.css -o styles.css --minify && tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "version": "node version-bump.mjs && git add manifest.json versions.json",
    "test": "bun test __tests__/",
    "changelog": "$HOME/go/bin/git-chglog -o CHANGELOG.md",
    "doc:code": "typedoc ",
    "qa": "obsidian plugin:reload vault=historica-test-vault id=historica"
  },
  "keywords": [
    "timeline",
    "nlp",
    "obsidian",
    "plugin"
  ],
  "author": "nhannht",
  "license": "MIT",
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "^20.19.39",
    "@types/unist": "^3.0.3",
    "@typescript-eslint/eslint-plugin": "5.29.0",
    "@typescript-eslint/parser": "5.29.0",
    "autoprefixer": "^10.4.27",
    "builtin-modules": "^5.0.0",
    "canvas": "^2.11.2",
    "concurrently": "^9.2.1",
    "esbuild": "^0.25.0",
    "esbuild-plugin-svgr": "^3.1.1",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "obsidian": "1.12.3",
    "postcss": "^8.5.9",
    "@codemirror/commands": "^6.0.0",
    "@codemirror/lang-markdown": "^6.0.0",
    "@codemirror/language": "^6.0.0",
    "@codemirror/state": "^6.0.0",
    "@codemirror/view": "^6.0.0",
    "@tailwindcss/cli": "^4.2.2",
    "tailwindcss": "^4.2.2",
    "tailwindcss-scoped-preflight": "^3.5.9",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "tslib": "2.4.0",
    "typedoc": "^0.27.9",
    "typedoc-plugin-inline-sources": "^1.3.0",
    "typedoc-theme-hierarchy": "^5.0.5",
    "typedoc-umlclass": "^0.10.2",
    "typescript": "6.0.2"
  },
  "dependencies": {
    "@nhannht/chrono-node": "^2.9.1",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@tanstack/react-virtual": "^3.13.23",
    "@types/d3": "^7.4.3",
    "@types/d3-scale": "^4.0.9",
    "@types/d3-shape": "^3.1.8",
    "@types/react": "19",
    "@types/react-dom": "19",
    "clsx": "^2.1.1",
    "d3": "^7.9.0",
    "d3-scale": "^4.0.2",
    "d3-shape": "^3.2.0",
    "franc": "^6.2.0",
    "html-to-image": "^1.11.13",
    "motion": "^12.38.0",
